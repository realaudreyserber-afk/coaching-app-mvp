rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ⚠️ TEMPORARY OPEN RULES — MVP DEV PHASE ONLY ⚠️
    // Anyone (signed-in or not) can read/write everything.
    // MUST be tightened back before public launch.
    // Previous strict rules: see git history before commit "open rules for MVP".
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
